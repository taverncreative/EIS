---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    num: 1,
    title: "Passenger / Goods lifts",
    desc: "Vertical transportation used for lifting people or goods including platform lifts, home lifts and dumbwaiters. We also offer more in-depth examinations and investigations into your lift including maintenance audits and condition surveys.",
    href: "/passenger-and-goods-lifts-inspections"
  },
  {
    num: 2,
    title: "Work at height equipment",
    desc: "From ladders and lanyards to harnesses and walkways, we ensure that all equipment your staff use for working at height is safe and reliable.",
    href: "/work-at-height-equipment-inspections"
  },
  {
    num: 3,
    title: "Cranes",
    desc: "Next time you're walking through a bustling city centre, take a look up and you may just see us carrying out the inspection of a tower crane! Others include goliath cranes, overhead cranes and gantry cranes to name but a few.",
    href: "/crane-inspections"
  },
  {
    num: 4,
    title: "Mobile Plant",
    desc: "We understand that some of your items can travel far and wide to carry out their duties, so you can rely on us to go wherever they go.",
    href: "/mobile-plant-inspection"
  },
  {
    num: 5,
    title: "Consultancy & Surveys",
    desc: "From maintenance audits and condition surveys to expert advice on compliance, our engineer surveyors are available to support you beyond the thorough examination.",
    href: "/#contact"
  },
  {
    num: 6,
    title: "Firefighting & Evacuation Lifts",
    desc: "We can undertake additional safety checks on these types of lifts in line with the new Fire Safety (England) Regulations 2022.",
    href: "/firefighting-and-evacuation-lift-inspections"
  },
  {
    num: 7,
    title: "Other services",
    desc: "We're here for you whenever you need us! Whether you need consultancy or advice, we're ready to assist. We also work closely with a trusted broker who can arrange insurance policies for you. Feel free to call or email us anytime.",
    href: "/#contact"
  }
];
---

<Layout title="Lifting Equipment Inspections | EIS" description="Independent LOLER and PUWER inspections for lifts, cranes, plant and access equipment across Kent, London and Essex.">
  
  <!-- Layout Header natively imported -->

  <!-- HERO SECTION -->
  <section class="relative bg-brand-navy pt-24 pb-16 lg:pb-32 z-20">
    <div class="max-w-[1500px] mx-auto px-6 relative z-20">

      <!-- HERO CONTENT -->
      <div class="flex items-center justify-between gap-16 mb-16">
        <!-- TEXT -->
        <div class="max-w-[650px]">
          <h1 class="text-5xl lg:text-[4rem] font-semibold text-white leading-tight">
            Thorough examinations
          </h1>
          <span class="block text-brand-orange text-5xl lg:text-[3.5rem] font-semibold mt-2">
            that work around you
          </span>
        </div>
        <!-- ARROW -->
        <div class="shrink-0 hidden lg:flex w-24 h-24 lg:w-36 lg:h-36 xl:w-40 xl:h-40 border-[1px] border-brand-orange rounded-full items-center justify-center transition hover:bg-brand-orange/10 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 lg:w-16 lg:h-16 xl:w-20 xl:h-20 text-white shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </div>
      </div>

      <!-- IMAGE -->
      <div class="relative z-10">
        <!-- Dots Decoration -->
        <div class="absolute right-2 -top-8 lg:right-0 lg:-top-10 w-[5rem] lg:w-[7rem] h-[5rem] lg:h-[7rem] z-30 mix-blend-screen pointer-events-none" style="background-image: url('/images/orange_circles.jpg'); background-size: contain; background-repeat: no-repeat; background-position: center;"></div>
        
        <div class="overflow-hidden rounded-2xl relative w-full h-[520px] md:h-[620px] xl:h-[720px] object-cover shadow-2xl">
          <img src="/images/crane-bg.png" class="absolute inset-0 w-full h-full object-cover hero-bg-pan z-10" alt="Tower crane on construction site during LOLER inspection" loading="eager" fetchpriority="high" width="1920" height="720" />
          <img src="/images/crane-fg.png" class="absolute inset-0 w-full h-full object-cover hero-fg-pan z-20" alt="Close-up of crane boom and jib being inspected" loading="eager" fetchpriority="high" width="1920" height="720" />
        </div>
      </div>

    </div>

    <!-- WHITE BACKGROUND LAYER -->
    <div class="absolute bottom-0 left-0 w-full h-[45%] bg-white z-10 pointer-events-none"></div>
  </section>

  <!-- CONTENT SECTION (Flows seamlessly from absolute layer bound) -->
  <section id="about-us" class="bg-white pt-16 lg:pt-32 pb-16 relative z-10 scroll-mt-24">
    <!-- MAIN ABOUT GRID -->
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 xl:grid-cols-12 gap-16">
      
      <!-- LEFT COLUMN: About Us Text + Regulations Grid -->
      <div class="xl:col-span-7 flex flex-col">
        <!-- About Us Content -->
        <h3 class="text-brand-orange font-black text-sm tracking-widest uppercase mb-8">About Us</h3>
        <h2 class="text-3xl lg:text-[2.2rem] font-normal leading-snug mb-8 text-slate-800 tracking-tight">
          Excel Inspection Solutions (EIS) is built on the foundation that more can be done to help clients remain compliant in a world governed by a variety of regulations.
        </h2>
        <p class="text-slate-400 font-medium mb-6 leading-relaxed text-[1.05rem]">
          Focusing on the needs of customers is the cornerstone of what led to the formation of EIS as our priority is to offer exemplary services and advice that work around you & your company.
        </p>
        <p class="text-slate-400 font-medium leading-relaxed text-[1.05rem] mb-16">
          Most of our clients are based in London and the South of England. However, as part of the Engineer Surveyor Inspection Network (ESiNet), a national network of Engineer Surveyors, we can call upon skilled and knowledgeable engineers to undertake examinations across the United Kingdom.
        </p>
        
        <!-- Grid of Acronyms -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          { 
            [
              { title: "L.O.L.E.R.", subtitle: "The Lifting Operations and Lifting Equipment Regulations 1998" },
              { title: "W.A.H.R.", subtitle: "The Work At Height Regulations 2005" },
              { title: "P.U.W.E.R.", subtitle: "The Provision and Use of Work Equipment Regulations 1998" },
              { title: "F.S.(E).R.", subtitle: "Fire Safety (England) Regulations 2022" },
              { title: "I.S.O. 9001", subtitle: "Quality Management System Certified" },
              { title: "I.S.O. 45001", subtitle: "Occupational Health & Safety Management System Certified" },
            ].map(item => (
              <div class="bg-slate-100/60 rounded-[2rem] p-10 flex flex-col items-center justify-center text-center transition hover:bg-slate-200/60 cursor-default">
                <h4 class="text-[1.5rem] font-normal text-brand-orange mb-3 tracking-wide">{item.title}</h4>
                <p class="text-slate-800 font-bold text-[0.8rem] leading-snug px-2">{item.subtitle}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- RIGHT COLUMN: Glass Door Full Height Image -->
      <div class="hidden xl:block xl:col-span-5 rounded-[2.5rem] overflow-hidden shadow-xl sticky top-8" style="height: calc(100vh - 4rem);">
        <img src="/images/glass_door.jpg" class="w-full h-full object-cover scale-105" alt="Glass passenger lift doors in a modern building" loading="lazy" width="800" height="1200" />
      </div>

    </div>
  </section>

  <!-- WHAT WE DO & FEATURES -->
  <section id="what-we-do" class="bg-brand-navy pt-32 pb-8 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-6">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20 items-start">
        <div>
          <h3 class="text-brand-orange font-bold text-sm tracking-widest uppercase mb-6">What We Do</h3>
          <h2 class="text-4xl md:text-5xl font-bold text-white tracking-tight">
            LOLER <span class="text-brand-orange">inspections</span>
          </h2>
        </div>
        <div>
          <p class="text-slate-300 text-lg leading-relaxed max-w-lg font-medium pt-2">
            We undertake LOLER thorough examinations for property management companies, chartered surveyors, construction firms and vehicle repair shops, which includes the delivery of a statutory report that is clear and coherent.
          </p>
        </div>
      </div>

      <!-- Feature Cards Grid (4 cards) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        
        <!-- Feature 1 -->
        <div class="bg-brand-navy border border-slate-700/60 rounded-[2.5rem] p-14 text-center">
          <div class="w-[84px] h-[84px] mx-auto rounded-full border border-brand-orange flex items-center justify-center mb-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
          </div>
          <h3 class="text-[1.6rem] font-bold text-white mb-6 tracking-wide">No <span class="text-brand-orange">Surprises</span></h3>
          <p class="text-slate-300 leading-relaxed text-[0.95rem]">
            There are no sudden surprises with us! When your assets are due for their inspection, we'll get in touch to make an appointment. We can even accommodate weekends at no additional cost in most situations.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-brand-navy border border-slate-700/60 rounded-[2.5rem] p-14 text-center">
          <div class="w-[84px] h-[84px] mx-auto rounded-full border border-brand-orange flex items-center justify-center mb-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-[1.6rem] font-bold text-white mb-6 tracking-wide">All <span class="text-brand-orange">Digital</span></h3>
          <p class="text-slate-300 leading-relaxed text-[0.95rem]">
            Your statutory and emergency reports are sent to you in digital form with photographs to help illustrate any issues. You can easily access your reports at any time through our user-friendly portal using a username and password that we provide for you.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-brand-navy border border-slate-700/60 rounded-[2.5rem] p-14 text-center mt-6">
          <div class="w-[84px] h-[84px] mx-auto rounded-full border border-brand-orange flex items-center justify-center mb-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 14v7" /></svg>
          </div>
          <h3 class="text-[1.6rem] font-bold text-white mb-6 tracking-wide">Highly <span class="text-brand-orange">Experienced</span></h3>
          <p class="text-slate-300 leading-relaxed text-[0.95rem]">
            A detailed thorough examination of your equipment is carried out by competent and knowledgeable surveyors with a wealth of experience across the disciplines we offer.
          </p>
        </div>

         <!-- Feature 4 -->
         <div class="bg-brand-navy border border-slate-700/60 rounded-[2.5rem] p-14 text-center mt-6">
          <div class="w-[84px] h-[84px] mx-auto rounded-full border border-brand-orange flex items-center justify-center mb-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          </div>
          <h3 class="text-[1.6rem] font-bold text-brand-orange mb-6 tracking-wide">24/7 <span class="text-white">Support</span></h3>
          <p class="text-slate-300 leading-relaxed text-[0.95rem]">
            Our services don't stop there! If you have any questions about your report or need assistance with anything else, such as consultancy or surveys, just get in touch. We're here for you 24/7.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- STICKY SERVICES SECTION -->
  <div id="services" class="pt-24 bg-brand-navy z-10 relative scroll-mt-24">
    <div class="max-w-7xl mx-auto px-6 lg:grid lg:pb-[10vh]" style="grid-template-columns: 30% 1fr; grid-template-rows: 1fr;">

      <!-- Left column: title -->
      <div class="sticky top-[80px] lg:top-[120px] self-start pr-0 lg:pr-8 mb-8 lg:mb-0" style="grid-column: 1; grid-row: 1; z-index: 5;">
        <h2 class="text-brand-orange font-bold text-sm tracking-widest mb-4 lg:mb-6">SERVICES</h2>
        <p class="text-xl lg:text-2xl font-bold leading-relaxed max-w-sm text-white tracking-tight">
          We offer a variety of other services that go <span class="text-brand-orange font-bold">much further</span> than our inspections:
        </p>
      </div>

      <!-- Right column: cards -->
      <div class="pt-8 lg:pt-0" style="grid-column: 2; grid-row: 1;">
        {services.map((service, index) => (
          <div class="contents">
            <a
              href={service.href}
              class={`service-card sticky top-[80px] lg:top-[120px] block h-[300px] lg:h-[450px] w-full bg-brand-navy border border-slate-700/60 rounded-[2.5rem] p-8 lg:p-14 shadow-2xl hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(242,139,3,0.15)] hover:border-brand-orange/40 group`}
              style={`z-index: ${10 + index * 10};`}
            >
              <div class="flex justify-between items-start mb-6 lg:mb-8">
                <div class="w-14 h-14 lg:w-16 lg:h-16 bg-brand-orange rounded-full flex items-center justify-center shadow-lg transition-transform group-hover:scale-110">
                  <span class="text-brand-navy font-black text-xl lg:text-2xl leading-none">{service.num}</span>
                </div>
                <div class="w-10 h-10 lg:w-12 lg:h-12 rounded-full border border-slate-700 flex items-center justify-center group-hover:bg-brand-orange group-hover:border-brand-orange transition-colors shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 lg:w-5 lg:h-5 text-slate-400 group-hover:text-brand-navy transition-colors duration-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </div>
              </div>
              <h3 class="text-2xl lg:text-3xl font-bold mb-3 lg:mb-4 text-white tracking-wide group-hover:text-brand-orange transition-colors">{service.title}</h3>
              <p class="text-slate-300 text-[0.95rem] lg:text-[1.05rem] leading-relaxed max-w-2xl font-medium">{service.desc}</p>
            </a>
          </div>
        ))}
      </div>

    </div>
  </div>


  <!-- SOLID ORANGE CONTACT GRID SECTION (MOVED ABOVE FORM) -->
  <section id="contact" class="bg-brand-orange text-brand-navy pt-24 pb-48 relative overflow-hidden z-20 scroll-mt-24">
    <div class="absolute left-0 top-0 w-32 h-32 opacity-20 pointer-events-none mix-blend-multiply" style="background-image: url('/images/orange_circles.jpg'); background-size: contain; background-repeat: no-repeat; background-position: top left;"></div>
    <div class="absolute right-0 bottom-0 w-32 h-32 opacity-20 pointer-events-none mix-blend-multiply" style="background-image: url('/images/orange_circles.jpg'); background-size: contain; background-repeat: no-repeat; background-position: bottom right;"></div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-0.5 bg-brand-navy"></div>
        <span class="font-bold text-sm tracking-widest uppercase">Get in touch</span>
      </div>
      
      <h2 class="text-4xl md:text-5xl font-bold mb-20 text-white tracking-tight">
        We'd love to hear from you
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8 xl:gap-0">
        <!-- Email Col -->
        <div class="xl:border-t-2 border-brand-navy/20 pt-8 xl:pr-10">
          <h4 class="font-medium text-lg mb-6 text-brand-navy">Email</h4>
          <a href="mailto:enquiries@eis-uk.com" class="block whitespace-nowrap text-white hover:text-brand-navy transition text-[1.1rem]">enquiries@eis-uk.com</a>
        </div>
        <!-- Phone Col -->
        <div class="xl:border-t-2 border-brand-navy/20 pt-8 xl:pr-10">
          <h4 class="font-medium text-lg mb-6 text-brand-navy">Phone</h4>
          <a href="tel:01634907073" class="text-white hover:text-brand-navy transition text-[1.1rem]">01634 907073</a>
        </div>
        <!-- Socials Col -->
        <div class="xl:border-t-2 border-brand-navy/20 pt-8 xl:pr-10">
          <h4 class="font-medium text-lg mb-6 text-brand-navy">Socials</h4>
          <ul class="space-y-3">
            <li><a href="https://www.instagram.com/eis_uk/" target="_blank" rel="noopener noreferrer" class="text-white hover:text-brand-navy transition text-[1.1rem]">Instagram</a></li>
            <li><a href="https://www.linkedin.com/company/eis-ltd" target="_blank" rel="noopener noreferrer" class="text-white hover:text-brand-navy transition text-[1.1rem]">Linkedin</a></li>
          </ul>
        </div>
        <!-- Address Col -->
        <div class="xl:border-t-2 border-brand-navy/20 pt-8">
          <h4 class="font-medium text-lg mb-6 text-brand-navy">Address</h4>
          <p class="text-white leading-loose text-[1.1rem]">
            Suite 2086,<br/>6-8 Revenge Rd,<br/>Chatham,<br/>ME5 8UD
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM SECTION OVERLAPPING -->
  <section class="bg-brand-navy pt-8 pb-32">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-stretch relative -mt-32 z-30">
      
      <!-- Left Image Overlapping -->
      <div class="lg:col-span-5 rounded-[2.5rem] overflow-hidden shadow-2xl min-h-[500px] lg:h-auto object-cover relative group">
        <img src="/images/lift_shaft.jpg" class="absolute inset-0 w-full h-full object-cover lift-shaft-zoom" alt="Inside a lift shaft during thorough examination" loading="lazy" width="800" height="1200" />
      </div>
      
      <!-- Right Form -->
      <div class="lg:col-span-7 flex flex-col justify-center pt-12 lg:pt-40">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-0.5 bg-brand-orange"></div>
          <span class="text-brand-orange font-bold text-sm tracking-widest uppercase">Get in touch</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-12 leading-tight tracking-tight">
          You can also contact us<br/><span class="text-brand-orange">using this form</span>
        </h2>
        
        <form id="contact-form" class="space-y-5">
          <div>
            <label class="block text-[0.85rem] text-slate-300 mb-2">Your Name *</label>
            <input type="text" name="name" class="w-full bg-brand-form border-none text-white rounded px-4 py-3 focus:ring-2 focus:ring-brand-orange transition-all outline-none" required />
          </div>
          <div>
            <label class="block text-[0.85rem] text-slate-300 mb-2">Your Email *</label>
            <input type="email" name="email" class="w-full bg-brand-form border-none text-white rounded px-4 py-3 focus:ring-2 focus:ring-brand-orange transition-all outline-none" required />
          </div>
          <div>
            <label class="block text-[0.85rem] text-slate-300 mb-2">Phone *</label>
            <div class="relative flex items-center bg-brand-form rounded overflow-hidden focus-within:ring-2 focus-within:ring-brand-orange">
              <div class="pl-4 pr-2 flex items-center gap-1 cursor-pointer">
                <span>🇬🇧</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-slate-400 mt-[1px]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
              </div>
              <input type="tel" name="phone" class="w-full bg-transparent border-none text-white px-3 py-3 outline-none" required />
            </div>
          </div>
          <div>
            <label class="block text-[0.85rem] text-slate-300 mb-2">Subject *</label>
            <input type="text" name="subject" class="w-full bg-brand-form border-none text-white rounded px-4 py-3 focus:ring-2 focus:ring-brand-orange transition-all outline-none" required />
          </div>
          <div>
            <label class="block text-[0.85rem] text-slate-300 mb-2">Your Message (Optional)</label>
            <textarea name="message" class="w-full bg-brand-form border-none text-white rounded px-4 py-3 focus:ring-2 focus:ring-brand-orange transition-all outline-none resize-none" rows="5"></textarea>
          </div>
          <div id="form-message" class="hidden text-sm font-medium py-3 px-4 rounded"></div>
          <div class="pt-2">
            <button type="submit" id="form-submit" class="w-full bg-slate-100 hover:bg-white text-slate-900 font-semibold text-[1rem] py-3 rounded transition-all tracking-wide">Submit</button>
          </div>
        </form>
        <script>
          const form = document.getElementById('contact-form');
          const btn = document.getElementById('form-submit');
          const msg = document.getElementById('form-message');

          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            btn.textContent = 'Sending...';
            msg.className = 'hidden text-sm font-medium py-3 px-4 rounded';

            const data = Object.fromEntries(new FormData(form));

            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
              });

              if (res.ok) {
                msg.textContent = 'Thank you — we\'ll be in touch shortly.';
                msg.className = 'text-sm font-medium py-3 px-4 rounded bg-green-900/40 text-green-300';
                form.reset();
              } else {
                throw new Error('Failed');
              }
            } catch {
              msg.textContent = 'Something went wrong. Please call us on 01634 907073.';
              msg.className = 'text-sm font-medium py-3 px-4 rounded bg-red-900/40 text-red-300';
            } finally {
              btn.disabled = false;
              btn.textContent = 'Submit';
            }
          });
        </script>
      </div>
    </div>
  </section>

  <!-- Layout Footer natively imported -->

</Layout>
