---
// src/pages/loler/[service]/[county]/[town].astro

import CountyPageLayout from '../../../../layouts/CountyPageLayout.astro';
import CTA from '../../../../components/CTA.astro';
import { locations, formatLocationName } from '../../../../data/locations';
import { serviceContent } from '../../../../data/serviceContent';
import { countyContent } from '../../../../data/countyContent';
import { townContent } from '../../../../data/townContent';

export async function getStaticPaths() {
  const services = [
    "lifting-equipment",
    "crane-inspections",
    "mobile-plant-inspection",
    "work-at-height-equipment-inspections",
    "garage-equipment-inspections",
    "passenger-and-goods-lifts-inspections",
    "firefighting-and-evacuation-lift-inspections"
  ];

  const counties = ["kent", "london", "essex"];

  const { locations } = await import('../../../../data/locations.js');

  const paths = [];

  for (const service of services) {
    for (const county of counties) {
      const towns = locations[county as keyof typeof locations] || [];

      for (const town of towns) {
        paths.push({
          params: { service, county, town }
        });
      }
    }
  }

  return paths;
}

const { service, county, town } = Astro.params;

const serviceMap: Record<string, string> = {
  "lifting-equipment": "Lifting Equipment Inspections",
  "crane-inspections": "Crane Inspections",
  "mobile-plant-inspection": "Mobile Plant Inspections",
  "work-at-height-equipment-inspections": "Access Equipment Inspections",
  "garage-equipment-inspections": "Garage Equipment Inspections",
  "passenger-and-goods-lifts-inspections": "Passenger and Goods Lift Inspections",
  "firefighting-and-evacuation-lift-inspections": "Firefighting and Evacuation Lift Inspections"
};

const serviceName = serviceMap[service as string] || "Inspection Services";
const towns = locations[county as keyof typeof locations] || [];
const nearbyTowns = towns.filter((t: string) => t !== town).slice(0, 5);

const formattedTown = formatLocationName(town as string);
const formattedCounty = formatLocationName(county as string);

// Pull unique content from data sources
const svcContent = serviceContent[service as keyof typeof serviceContent];
const ctyContent = countyContent[county as keyof typeof countyContent];
const twnContent = townContent[town as keyof typeof townContent];

const seoTitle = `${serviceName} in ${formattedTown}, ${formattedCounty} | LOLER Compliance`;
const seoDescription = `${serviceName} in ${formattedTown} — independent thorough examinations covering ${svcContent?.whatWeInspect?.slice(0, 3).join(', ').toLowerCase() || 'lifting equipment'}. LOLER and PUWER compliant. Book today.`;

// Build rich structured data
const faqSchema = svcContent?.faq ? {
  "@type": "FAQPage",
  "mainEntity": svcContent.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
} : null;

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": `${serviceName} in ${formattedTown}`,
    "description": seoDescription,
    "areaServed": {
      "@type": "Place",
      "name": formattedTown,
      "containedInPlace": {
        "@type": "AdministrativeArea",
        "name": formattedCounty
      }
    },
    "provider": {
      "@type": "Organization",
      "name": "Excel Inspection Solutions",
      "url": "https://www.eis-uk.com"
    },
    "serviceType": serviceName,
    "termsOfService": "https://www.eis-uk.com/faq"
  },
  ...(faqSchema ? [{ "@context": "https://schema.org", ...faqSchema }] : [])
]);

// Determine which sections to show and in what order based on service type
// This creates layout variation between service types
const showDefectsFirst = ["crane-inspections", "mobile-plant-inspection"].includes(service as string);
const showEquipmentAsGrid = ["lifting-equipment", "garage-equipment-inspections"].includes(service as string);

// Find overlapping sectors between service and town
const overlappingSectors = (svcContent?.typicalSectors && twnContent?.keySectors)
  ? svcContent.typicalSectors.filter(s =>
      twnContent.keySectors.some(ts =>
        s.toLowerCase().includes(ts.toLowerCase().split(' ')[0]) ||
        ts.toLowerCase().includes(s.toLowerCase().split(' ')[0])
      )
    )
  : [];
---

<CountyPageLayout
  title={seoTitle}
  description={seoDescription}
  serviceName={serviceName}
  serviceSlug={service}
  county={`${formattedCounty} / ${formattedTown}`}
>
  <script type="application/ld+json" set:html={schema} slot="head" />

  <!-- Service-specific introduction with local context -->
  <p class="lead text-lg text-slate-600 mb-6">
    {svcContent?.intro || `We provide independent ${serviceName.toLowerCase()} across ${formattedTown} and the surrounding area.`}
  </p>

  {twnContent && (
    <p class="text-slate-700 mb-8">
      {twnContent.localContext} Our Engineer Surveyors provide {serviceName.toLowerCase()} to businesses throughout {formattedTown} and nearby areas including {twnContent.nearbyAreas.slice(0, 3).join(', ')}.
    </p>
  )}

  <!-- Equipment list section — varies layout per service type -->
  <h2 class="text-2xl font-semibold text-slate-900 mt-12 mb-4">What We Inspect in {formattedTown}</h2>
  {showEquipmentAsGrid ? (
    <div class="grid sm:grid-cols-2 gap-2 mb-6">
      {svcContent?.whatWeInspect?.map((item: string) => (
        <div class="flex items-start gap-2 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-orange mt-2 shrink-0"></span>
          <span class="text-slate-700">{item}</span>
        </div>
      ))}
    </div>
  ) : (
    <ul class="list-disc pl-5 mb-6 space-y-1 text-slate-700">
      {svcContent?.whatWeInspect?.map((item: string) => (
        <li>{item}</li>
      ))}
    </ul>
  )}
  <p class="mb-4 text-slate-700">
    {svcContent?.inspectionDetails}
  </p>

  {/* Show defects section early for crane/plant, later for others */}
  {showDefectsFirst && svcContent?.commonDefects && (
    <>
      <h2 class="text-2xl font-semibold text-slate-900 mt-12 mb-4">Common Issues Identified During Inspections</h2>
      <p class="mb-3 text-slate-700">
        Our Engineer Surveyors regularly identify the following types of defects during {serviceName.toLowerCase()}:
      </p>
      <ul class="list-disc pl-5 mb-6 space-y-1 text-slate-700">
        {svcContent.commonDefects.map((defect: string) => (
          <li>{defect}</li>
        ))}
      </ul>
    </>
  )}

  <!-- Industries and sectors — combines town + service data -->
  <h2 class="text-2xl font-semibold text-slate-900 mt-12 mb-4">Industries We Support in {formattedTown}</h2>
  {twnContent ? (
    <p class="mb-4 text-slate-700">
      {formattedTown}'s local economy includes {twnContent.keySectors.slice(0, 3).join(', ').toLowerCase()}{twnContent.keySectors.length > 3 ? `, and ${twnContent.keySectors[3].toLowerCase()}` : ''} — sectors where {serviceName.toLowerCase()} are regularly required to maintain legal compliance and workplace safety.
    </p>
  ) : (
    <p class="mb-4 text-slate-700">
      Our {serviceName.toLowerCase()} support businesses across a range of sectors in {formattedTown}.
    </p>
  )}
  <p class="mb-4 text-slate-700">
    Across {formattedCounty}, {ctyContent?.sectorMix || `businesses across multiple sectors rely on regular thorough examinations to maintain LOLER and PUWER compliance.`}
  </p>

  {/* Notable local areas callout */}
  {twnContent?.localLandmarks && twnContent.localLandmarks.length > 0 && (
    <div class="my-8 p-5 bg-slate-50 border border-slate-200 rounded-xl">
      <p class="text-slate-700 font-medium mb-2">Local Coverage Areas</p>
      <p class="text-slate-600 text-sm">
        We provide {serviceName.toLowerCase()} to businesses at and around {twnContent.localLandmarks.join(', ')}, as well as across the wider {formattedTown} area.
      </p>
    </div>
  )}

  <!-- Regulation and compliance — service-specific -->
  <h2 class="text-2xl font-semibold text-slate-900 mt-12 mb-4">Inspection Frequency and Legal Requirements</h2>
  <p class="mb-4 text-slate-700">
    {svcContent?.regulationNotes}
  </p>
  <div class="my-6 p-5 bg-brand-orange/5 border border-brand-orange/20 rounded-xl">
    <p class="text-slate-800 font-semibold mb-1">Required Inspection Interval</p>
    <p class="text-slate-700">{svcContent?.inspectionFrequency || 'Intervals vary depending on equipment type and use.'}</p>
  </div>

  {/* Show defects section here for non-crane/plant services */}
  {!showDefectsFirst && svcContent?.commonDefects && (
    <>
      <h2 class="text-2xl font-semibold text-slate-900 mt-12 mb-4">Common Defects Found</h2>
      <p class="mb-3 text-slate-700">
        During {serviceName.toLowerCase()} in {formattedTown} and the wider {formattedCounty} area, our Engineer Surveyors commonly identify:
      </p>
      <ul class="list-disc pl-5 mb-6 space-y-1 text-slate-700">
        {svcContent.commonDefects.map((defect: string) => (
          <li>{defect}</li>
        ))}
      </ul>
    </>
  )}

  <!-- Regional context -->
  {ctyContent?.regionalNotes && (
    <>
      <h2 class="text-2xl font-semibold text-slate-900 mt-12 mb-4">Covering {formattedTown} and {formattedCounty}</h2>
      <p class="mb-4 text-slate-700">
        {ctyContent.regionalNotes}
      </p>
    </>
  )}

  <!-- FAQ section with schema markup -->
  {svcContent?.faq && svcContent.faq.length > 0 && (
    <>
      <h2 class="text-2xl font-semibold text-slate-900 mt-12 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-6 mb-8">
        {svcContent.faq.map((item: { q: string; a: string }) => (
          <div class="border-b border-slate-200 pb-5">
            <h3 class="text-lg font-semibold text-slate-900 mb-2">{item.q}</h3>
            <p class="text-slate-700">{item.a}</p>
          </div>
        ))}
      </div>
    </>
  )}

  <hr class="my-12 border-slate-200" />

  <!-- Internal linking section (preserved from original) -->
  <section class="mt-16 border-t pt-10">
    <div class="mt-12 pt-8 border-t border-slate-200">
      <h3 class="text-xl font-semibold text-slate-900 mt-8 mb-3">{serviceName} in {formattedCounty}</h3>
      <ul class="grid md:grid-cols-2 gap-3">
        <li>
          <a href={`/loler/${service}/${county}/`} class="font-medium text-slate-800 hover:text-brand-orange transition flex items-center gap-2">
             <span class="w-1.5 h-1.5 rounded-full bg-brand-orange"></span>
            {serviceName} in {formattedCounty}
          </a>
        </li>
      </ul>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-200">
      <h3 class="text-xl font-semibold text-slate-900 mt-8 mb-3">All {serviceName}</h3>
      <ul class="grid md:grid-cols-2 gap-3">
        <li>
          <a href={service === 'lifting-equipment' ? `/${service}-inspections` : `/${service}`} class="font-medium text-slate-800 hover:text-brand-orange transition flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-orange"></span>
            View all {serviceName.toLowerCase()} across the UK
          </a>
        </li>
      </ul>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-200">
      <h3 class="text-xl font-semibold text-slate-900 mt-8 mb-3">Nearby {serviceName} Areas</h3>
      <ul class="grid sm:grid-cols-2 gap-3">
        {nearbyTowns.map((t: string) => (
          <li>
            <a href={`/loler/${service}/${county}/${t}/`} class="font-medium text-slate-800 hover:text-brand-orange transition flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-orange"></span>
              {serviceName} in {formatLocationName(t)}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTA town={formattedTown} />

</CountyPageLayout>
