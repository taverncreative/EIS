---
import CountyPageLayout from '../../../layouts/CountyPageLayout.astro';
import CountyContent from '../../../components/CountyContent.astro';
import { locations, formatLocationName } from '../../../data/locations';
import { serviceContent } from '../../../data/serviceContent';
import { getShortServiceName, buildTitle, buildDescription } from '../../../utils/seo';

const serviceName = "Crane Inspections";
const serviceSlug = "crane-inspections";
const county = "essex";

const towns = locations[county];
const siblings = [
  { name: "Kent", slug: "kent" },
  { name: "London", slug: "london" }
];

const formattedCountyName = formatLocationName(county);
const svcContent = serviceContent[serviceSlug as keyof typeof serviceContent];
const shortName = getShortServiceName(serviceSlug);
const seoTitle = buildTitle(shortName, undefined, formattedCountyName);
const seoDescription = buildDescription(shortName, { county: formattedCountyName });

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${serviceName} in ${formattedCountyName}`,
  "description": seoDescription,
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": formattedCountyName
  },
  "provider": {
    "@type": "Organization",
    "name": "Excel Inspection Solutions",
    "url": "https://www.eis-uk.com"
  },
  "serviceType": serviceName
});
---

<CountyPageLayout
  title={seoTitle}
  description={seoDescription}
  serviceName={serviceName}
  serviceSlug={serviceSlug}
  county={formatLocationName(county)}
>
  <script type="application/ld+json" set:html={schema} slot="head" />

  <CountyContent
    serviceSlug={serviceSlug}
    serviceName={serviceName}
    county={county}
    towns={towns}
    siblings={siblings}
  />
</CountyPageLayout>
