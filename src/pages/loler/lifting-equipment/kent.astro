---
import CountyPageLayout from '../../../layouts/CountyPageLayout.astro';
import CountyContent from '../../../components/CountyContent.astro';
import { locations, formatLocationName } from '../../../data/locations';
import { serviceContent } from '../../../data/serviceContent';

const serviceName = "Lifting Equipment Inspections";
const serviceSlug = "lifting-equipment";
const county = "kent";

const towns = locations[county];
const siblings = [
  { name: "London", slug: "london" },
  { name: "Essex", slug: "essex" }
];

const formattedCountyName = formatLocationName(county);
const svcContent = serviceContent[serviceSlug as keyof typeof serviceContent];
const seoTitle = `${serviceName} in ${formattedCountyName} | LOLER & PUWER Compliance`;
const seoDescription = `Independent ${serviceName.toLowerCase()} across ${formattedCountyName}. Covering ${svcContent?.whatWeInspect?.slice(0, 3).join(', ').toLowerCase() || 'lifting equipment'}. LOLER compliant thorough examinations.`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${serviceName} in ${formattedCountyName}`,
  "description": seoDescription,
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": formattedCountyName
  },
  "provider": {
    "@type": "Organization",
    "name": "Excel Inspection Solutions",
    "url": "https://www.eis-uk.com"
  },
  "serviceType": serviceName
});
---

<CountyPageLayout
  title={seoTitle}
  description={seoDescription}
  serviceName={serviceName}
  serviceSlug={serviceSlug}
  county={formatLocationName(county)}
>
  <script type="application/ld+json" set:html={schema} slot="head" />

  <CountyContent
    serviceSlug={serviceSlug}
    serviceName={serviceName}
    county={county}
    towns={towns}
    siblings={siblings}
  />
</CountyPageLayout>
