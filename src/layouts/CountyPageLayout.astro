---
import Layout from './Layout.astro';
import Hero from '../components/Hero.astro';
import ContentSection from '../components/ContentSection.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';

const { title, description, serviceName, serviceSlug, county } = Astro.props;

const siteBase = 'https://www.eis-uk.com';
const servicePageSlug = serviceSlug === 'lifting-equipment' ? 'lifting-equipment-inspections' : serviceSlug;
const breadcrumbs = [
  { name: 'Home', url: siteBase },
  { name: serviceName, url: `${siteBase}/${servicePageSlug}` },
  { name: county, url: `${siteBase}${Astro.url.pathname}` }
];
---
<Layout title={`${title} | Excel Inspection Solutions`} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={breadcrumbs} />
    <slot name="head" />
  </Fragment>
  <!-- Lightweight Hero -->
  <Hero title={title} subtitle="Local Service Hub" />

  <ContentSection>
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-6 flex flex-wrap items-center gap-2 border-b border-slate-100 pb-6">
      <a href="/" class="hover:text-brand-orange transition">Home</a>
      <span class="text-slate-300">/</span>
      <a href={`/${serviceSlug}-inspections`} class="hover:text-brand-orange transition">Services</a>
      <span class="text-slate-300">/</span>
      <a href={`/${serviceSlug}-inspections`} class="hover:text-brand-orange transition">{serviceName}</a>
      <span class="text-slate-300">/</span>
      <span class="text-slate-800">{county}</span>
    </nav>

    <!-- Content Slot -->
    <slot />
  </ContentSection>
</Layout>
