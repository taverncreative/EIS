---
import '../styles/global.css';
import OrganisationSchema from '../components/schema/OrganisationSchema.astro';
import LocalBusinessSchema from '../components/schema/LocalBusinessSchema.astro';

const {
  title = "Excel Inspection Solutions",
  description = "Independent statutory examinations and lifting equipment inspections supporting LOLER and PUWER compliance.",
  ogImage = "/images/crane.jpg",
  ogType = "website"
} = Astro.props;

// Strip trailing slashes to match trailingSlash: 'never' config
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonicalURL = new URL(pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en-GB" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Performance: preconnect to third-party origins (web-vitals CDN, unpkg) -->
    <link rel="preconnect" href="https://unpkg.com" crossorigin />
    <link rel="dns-prefetch" href="https://unpkg.com" />

    <!-- Performance: preload logo (WebP, used in nav on every page, above the fold) -->
    <link rel="preload" as="image" href="/images/logo.webp" type="image/webp" fetchpriority="high" />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en-GB" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Excel Inspection Solutions" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <OrganisationSchema />
    <LocalBusinessSchema />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Excel Inspection Solutions",
      "url": "https://www.eis-uk.com",
      "publisher": { "@id": "https://www.eis-uk.com/#organisation" }
    })} />
    <slot name="head" />

    <!-- Core Web Vitals tracking (lightweight, non-blocking) -->
    <script>
      // Inline CWV reporting using the web-vitals CDN module
      // Reports LCP, FID, CLS, FCP, TTFB to console + sends to /api/vitals if available
      (function() {
        function sendToAnalytics(metric) {
          // Log to console in development
          if (typeof console !== 'undefined') {
            console.log('[CWV]', metric.name, Math.round(metric.value), metric.rating);
          }

          // Send to analytics endpoint if available (e.g., Vercel Analytics)
          if (typeof navigator !== 'undefined' && navigator.sendBeacon) {
            const body = JSON.stringify({
              name: metric.name,
              value: metric.value,
              rating: metric.rating,
              id: metric.id,
              page: window.location.pathname,
            });
            navigator.sendBeacon('/api/vitals', body);
          }
        }

        // Dynamically import web-vitals from CDN
        import('https://unpkg.com/web-vitals@4/dist/web-vitals.attribution.js?module').then(function(mod) {
          mod.onCLS(sendToAnalytics);
          mod.onFCP(sendToAnalytics);
          mod.onLCP(sendToAnalytics);
          mod.onTTFB(sendToAnalytics);
          mod.onINP(sendToAnalytics);
        }).catch(function() {
          // Silently fail — CWV tracking is non-critical
        });
      })();
    </script>
  </head>
  <body class="bg-brand-navy min-h-screen text-slate-900 flex flex-col font-sans">
