---
import '../styles/global.css';

const { title = "Excel Inspection Solutions", description = "Independent statutory examinations and lifting equipment inspections supporting LOLER and PUWER compliance." } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || 'https://www.excel-inspection-solutions.co.uk')} />
    <slot name="head" />
  </head>
  <body class="bg-brand-navy min-h-screen text-slate-900 flex flex-col font-sans">
    <div class="desktop-only text-sm border-b border-brand-navy/30 py-3 hidden lg:block bg-[#0f172a] absolute w-full z-50"></div>
    
    <!-- NAVBAR -->
    <nav class="w-full relative z-50 bg-brand-navy">
      <div class="max-w-[1600px] mx-auto px-6 md:px-8 py-6 flex flex-wrap lg:flex-nowrap items-center justify-between relative">
        <a href="/" class="flex flex-col shrink-0 group z-50">
          <img src="/images/logo.png" alt="Excel Inspection Solutions" class="h-10 md:h-12 w-auto object-contain transition duration-300 group-hover:opacity-90" />
        </a>
        
        <!-- Mobile Toggle & Brochure Group -->
        <div class="flex items-center gap-3 lg:hidden z-50">
          <a href="/#contact" class="bg-brand-orange hover:bg-orange-600 text-slate-900 font-extrabold py-2 px-4 rounded-[0.7rem] text-[0.8rem] shadow-lg shadow-brand-orange/20 transition whitespace-nowrap">
            Request Quote
          </a>
          <button id="mobile-menu-btn" class="text-white p-2" aria-label="Toggle Menu">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
          </button>
        </div>

        <ul id="nav-menu" class="hidden lg:flex w-full lg:w-auto flex-col lg:flex-row items-start lg:items-center gap-6 lg:gap-12 text-[1rem] font-bold text-slate-400 mt-8 lg:mt-0 pb-6 lg:pb-0">
          <li><a href="/" class="hover:text-brand-orange text-brand-orange border-b-2 border-brand-orange pb-0.5 transition">Home</a></li>
          <li><a href="/#about-us" class="hover:text-white transition">About Us</a></li>
          <li><a href="/#what-we-do" class="hover:text-white transition">What We Do</a></li>
          
          <!-- MEGA MENU -->
          <li class="relative group">
            <a href="/#services" class="hover:text-white transition flex items-center gap-1 py-4 lg:py-0">
              Services <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1 transition group-hover:rotate-180" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
            <!-- Dropdown Panel -->
            <div class="lg:absolute left-1/2 lg:-translate-x-1/2 top-full lg:pt-8 
                        hidden group-hover:block w-full lg:w-max opacity-0 group-hover:opacity-100 transition-opacity duration-200">
              <div class="bg-[#0e1628] lg:border border-slate-700/60 rounded-2xl shadow-2xl p-8 px-12 grid grid-cols-1 md:grid-cols-2 gap-x-24 gap-y-5 relative">
                <!-- invisible connector to prevent hover dropout -->
                <div class="absolute -top-8 left-0 right-0 h-8 bg-transparent"></div>
                <div class="flex flex-col gap-4">
                  <a href="/lifting-equipment-inspections" class="hover:text-brand-orange transition whitespace-nowrap text-white font-semibold">Lifting Equipment Inspections</a>
                  <a href="/work-at-height-equipment-inspections" class="hover:text-brand-orange transition whitespace-nowrap text-white font-semibold">Work at height equipment</a>
                  <a href="/mobile-plant-inspection" class="hover:text-brand-orange transition whitespace-nowrap text-white font-semibold">Mobile Plant</a>
                  <a href="/garage-equipment-inspections" class="hover:text-brand-orange transition whitespace-nowrap text-white font-semibold">Garage Equipment</a>
                </div>
                <div class="flex flex-col gap-4">
                  <a href="/passenger-and-goods-lifts-inspections" class="hover:text-brand-orange transition whitespace-nowrap text-white font-semibold">Passenger & Goods Lift Inspections</a>
                  <a href="/crane-inspections" class="hover:text-brand-orange transition whitespace-nowrap text-white font-semibold">Cranes</a>
                  <a href="/firefighting-and-evacuation-lift-inspections" class="hover:text-brand-orange transition whitespace-nowrap text-white font-semibold">Firefighting & Evacuation Lift Inspection</a>
                </div>
              </div>
            </div>
          </li>
          
          <li><a href="/faq" class="hover:text-white transition">FAQ</a></li>
          
          <li class="lg:hidden mt-4 pt-4 border-t border-slate-700/50 w-full text-center">
            <a href="tel:01634907073" class="text-white font-medium hover:text-brand-orange transition flex items-center justify-center gap-2">
              📞 01634 907073
            </a>
          </li>
          <li class="lg:hidden mt-4">
             <a href="/EIS Brochure 2025_Final.pdf" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition whitespace-nowrap font-medium text-sm flex items-center justify-center">
                View Brochure
              </a>
          </li>
        </ul>
        
        <div class="hidden lg:flex items-center gap-6">
          <a href="tel:01634907073" class="text-white font-medium hover:text-brand-orange transition whitespace-nowrap">
            📞 01634 907073
          </a>
          <a href="/#contact" class="bg-brand-orange hover:bg-orange-600 text-slate-900 font-extrabold py-2.5 px-6 rounded-[1rem] text-base shadow-lg shadow-brand-orange/20 transition whitespace-nowrap">
            Request a Quote
          </a>
          <a href="/EIS Brochure 2025_Final.pdf" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition whitespace-nowrap font-medium text-sm hidden xl:block">
            View Brochure
          </a>
        </div>
      </div>
    </nav>
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('nav-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
          menu.classList.toggle('flex');
        });
      }
    </script>
    
    <slot />

    <!-- FOOTER SECTION -->
    <footer class="bg-brand-footer pt-24 pb-12 border-t border-slate-800">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-12 mb-20">
        
        <!-- Logo Col -->
        <div class="col-span-1 md:col-span-4 lg:col-span-5">
          <img src="/images/logo.png" alt="Excel Inspection Solutions" class="h-12 md:h-14 w-auto object-contain mb-6" />
          <div class="flex items-center gap-4 text-slate-300 mt-8">
            <a href="https://www.instagram.com/eis_uk/" target="_blank" rel="noopener noreferrer" class="block hover:-translate-y-1 transition duration-300">
              <img src="/images/Instagram%20Icon.png" alt="Instagram" class="w-9 h-9 object-contain hover:grayscale-0" />
            </a>
            <a href="https://www.linkedin.com/company/eis-ltd" target="_blank" rel="noopener noreferrer" class="block hover:-translate-y-1 transition duration-300">
              <img src="/images/Linkedin%20Icon.png" alt="LinkedIn" class="w-9 h-9 object-contain hover:grayscale-0" />
            </a>
          </div>
        </div>
        
        <!-- Location Col -->
        <div class="col-span-1 md:col-span-4 lg:col-span-3">
          <h4 class="text-brand-orange font-medium text-2xl mb-6">Location</h4>
          <p class="text-slate-300 leading-loose text-[1.05rem]">
            Suite 2086,<br/>6-8 Revenge Road<br/>Chatham ME5 8UD
          </p>
        </div>

        <!-- Contact Col -->
        <div class="col-span-1 md:col-span-4 lg:col-span-4 flex flex-col items-start xl:items-end w-full">
          <div class="w-full flex flex-col md:flex-row gap-8 justify-between">
            <div>
              <h4 class="text-brand-orange font-medium text-2xl mb-6">Contact</h4>
              <a href="mailto:enquiries@eis-uk.com" class="block whitespace-nowrap text-slate-300 text-[1.05rem] hover:text-brand-orange mb-3 transition">enquiries@eis-uk.com</a>
              <a href="tel:01634907073" class="block whitespace-nowrap text-slate-300 text-[1.05rem] hover:text-brand-orange transition">01634 907073</a>
            </div>
            
            <div class="flex gap-4 items-end justify-end mt-4 md:mt-0">
              <img src="/images/iso_45001.jpg" alt="ISO 45001 UKAS" class="w-[85px] h-[100px] object-contain shadow-lg border-2 border-slate-200 bg-white" />
              <img src="/images/iso_9001.jpg" alt="ISO 9001 UKAS" class="w-[85px] h-[100px] object-contain shadow-lg border-2 border-slate-200 bg-white" />
            </div>
          </div>
        </div>
        
      </div>

      <!-- SEO INTERNAL LINKING ROWS -->
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8 mb-12 border-t border-slate-800/50 pt-12">
        <div>
          <h4 class="text-brand-orange font-semibold mb-3">Core Services</h4>
          <ul class="space-y-2 text-[0.95rem] text-slate-300">
            <li><a href="/lifting-equipment-inspections/" class="hover:text-brand-orange transition">Lifting Equipment Inspections</a></li>
            <li><a href="/crane-inspections/" class="hover:text-brand-orange transition">Crane Inspections</a></li>
            <li><a href="/passenger-and-goods-lifts-inspections/" class="hover:text-brand-orange transition">Passenger & Goods Lift Inspections</a></li>
            <li><a href="/work-at-height-equipment-inspections/" class="hover:text-brand-orange transition">Work at Height Equipment Inspections</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-brand-orange font-semibold mb-3">Specialist Inspections</h4>
          <ul class="space-y-2 text-[0.95rem] text-slate-300">
             <li><a href="/mobile-plant-inspection/" class="hover:text-brand-orange transition">Mobile Plant Inspections</a></li>
             <li><a href="/garage-equipment-inspections/" class="hover:text-brand-orange transition">Garage Equipment Inspections</a></li>
             <li><a href="/firefighting-and-evacuation-lift-inspections/" class="hover:text-brand-orange transition">Firefighting & Evacuation Lifts</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-brand-orange font-semibold mb-3">Key Locations</h4>
          <ul class="space-y-2 text-[0.95rem] text-slate-300">
            <li><a href="/loler/lifting-equipment/kent/" class="hover:text-brand-orange transition">Lifting Equipment in Kent</a></li>
            <li><a href="/loler/lifting-equipment/london/" class="hover:text-brand-orange transition">Lifting Equipment in London</a></li>
            <li><a href="/loler/lifting-equipment/essex/" class="hover:text-brand-orange transition">Lifting Equipment in Essex</a></li>
          </ul>
        </div>
      </div>
      
      <div class="max-w-7xl mx-auto px-6 border-t border-slate-800 pt-8 flex flex-col md:flex-row gap-4 justify-between items-center text-[0.95rem] text-slate-500 font-medium">
        <p>Copyright ©2026 <span class="text-brand-orange font-semibold">Excel</span> Inspection Solutions. All rights reserved.</p>
        <p>Website by <a href="https://www.businesssortedkent.co.uk/" target="_blank" rel="noopener noreferrer" class="text-brand-orange hover:text-orange-400 transition font-semibold">BSK</a></p>
      </div>
    </footer>

  </body>
</html>
